* text=auto eol=lf

# Ensure Windows scripts keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary blobs
*.glb   binary
*.gltf  binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.mp3   binary
*.mp4   binary
*.zip   binary
